# ==============================================
# APPLICATION
# ==============================================
APP_ENV="local"
APP_NAME="nestjs-starter"
APP_DEBUG=true
APP_LOG_LEVEL="debug"
# Comma-separated list of allowed CORS origins (use "*" for any)
APP_CORS_ORIGINS="*"

# ==============================================
# HTTP SERVER
# ==============================================
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

# ==============================================
# ERROR TRACKING (optional)
# ==============================================
SENTRY_DSN=""

# ==============================================
# AUTH / JWT
# ==============================================
# Generate strong secrets, e.g. `openssl rand -base64 32`
AUTH_ACCESS_TOKEN_SECRET="change-me-access"
AUTH_REFRESH_TOKEN_SECRET="change-me-refresh"
AUTH_ACCESS_TOKEN_EXP="1d"
AUTH_REFRESH_TOKEN_EXP="7d"

# ==============================================
# CLAVES ENCRYPTION (AES-256-GCM)
# ==============================================
# Key used to encrypt/decrypt fiscal keys and passwords stored in
# claves_estudio and claves_cliente tables.
# MUST be identical across ALL environments that share the same DB.
# Generate with: openssl rand -base64 32
CLAVES_ENCRYPTION_KEY="change-me-claves"

# ==============================================
# DATABASE
# ==============================================
DATABASE_URL="postgresql://postgres:master123@localhost:5432/postgres?schema=public"

# ==============================================
# REDIS (cache + Bull queues)
# ==============================================
# Use rediss:// for TLS
REDIS_URL="redis://localhost:6379"

# ==============================================
# CLOUDFLARE R2 — Object Storage (S3-compatible)
# ==============================================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Optional: public base URL for direct access (e.g. CDN)
R2_PUBLIC_URL=""
# Optional: region override (default "auto" = R2 global)
R2_REGION="auto"

# ==============================================
# SEED DATA — used by `npm run seed:admin` / `remove:admin`
# ==============================================
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="Admin@1234"
SEED_ADMIN_USERNAME="admin"
