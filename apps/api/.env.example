# ==============================================
# APPLICATION
# ==============================================
APP_ENV="local"
APP_NAME="nestjs-starter"
APP_DEBUG=true
APP_LOG_LEVEL="debug"
# Comma-separated list of allowed CORS origins (use "*" for any)
APP_CORS_ORIGINS="*"

# ==============================================
# HTTP SERVER
# ==============================================
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

# ==============================================
# ERROR TRACKING (optional)
# ==============================================
SENTRY_DSN=""

# ==============================================
# AUTH / JWT
# ==============================================
# Generate strong secrets, e.g. `openssl rand -base64 32`
AUTH_ACCESS_TOKEN_SECRET="change-me-access"
AUTH_REFRESH_TOKEN_SECRET="change-me-refresh"
AUTH_ACCESS_TOKEN_EXP="1d"
AUTH_REFRESH_TOKEN_EXP="7d"

# ==============================================
# DATABASE
# ==============================================
DATABASE_URL="postgresql://postgres:master123@localhost:5432/postgres?schema=public"

# ==============================================
# REDIS (cache + Bull queues)
# ==============================================
# Use rediss:// for TLS
REDIS_URL="redis://localhost:6379"

# ==============================================
# SEED DATA — used by `npm run seed:admin` / `remove:admin`
# ==============================================
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="Admin@1234"
SEED_ADMIN_USERNAME="admin"
