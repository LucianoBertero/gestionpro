{
    "name": "nestjs-starter",
    "version": "1.0.0",
    "description": "Lean NestJS starter with JWT auth, Prisma/PostgreSQL, Redis cache, BullMQ scaffolding, Pino logging, i18n and Swagger.",
    "author": "hmake98",
    "license": "MIT",
    "private": true,
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "prepare": "husky",
        "prebuild": "rimraf dist",
        "build": "prisma generate && nest build",
        "start": "node dist/main",
        "dev": "nest start --watch",
        "debug": "nest start --debug --watch",
        "update:packages": "npx npm-check-updates -u",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate-prod": "prisma migrate deploy",
        "cli": "ts-node -r tsconfig-paths/register src/cli.ts",
        "seed:admin": "npm run cli -- seed:admin",
        "remove:admin": "npm run cli -- remove:admin",
        "make-badges": "istanbul-badges-readme",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "format:fix": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "test": "jest --config test/jest.json --coverage --runInBand --passWithNoTests --forceExit",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config test/jest.json --runInBand"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1075.0",
        "@aws-sdk/s3-request-presigner": "^3.1075.0",
        "@faker-js/faker": "^10.4.0",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.1.19",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.19",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.19",
        "@nestjs/schedule": "^6.1.3",
        "@nestjs/swagger": "^11.4.2",
        "@nestjs/terminus": "^11.1.1",
        "@nestjs/throttler": "^6.5.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "7.8.0",
        "@sentry/node": "^10.51.0",
        "argon2": "^0.44.0",
        "bullmq": "^5.76.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "file-type": "^22.0.1",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.1",
        "multer": "^2.0.0",
        "nestjs-command": "^3.1.5",
        "nestjs-i18n": "^10.8.4",
        "nestjs-pino": "^4.6.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.20.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "prisma": "7.8.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "swagger-ui-express": "^5.0.1",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.3",
        "@commitlint/config-conventional": "^20.5.3",
        "@eslint/js": "^10.0.1",
        "@nestjs/cli": "^11.0.21",
        "@nestjs/testing": "^11.1.19",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.33",
        "@swc/jest": "^0.2.39",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.6.0",
        "@types/passport": "^1.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "cross-env": "^10.1.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "istanbul-badges-readme": "^1.9.0",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.9",
        "ts-loader": "^9.5.7",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "6.0.3",
        "typescript-eslint": "^8.59.2"
    },
    "lint-staged": {
        "{src,test}/**/*.{ts,js}": [
            "prettier --write",
            "eslint --fix"
        ],
        "{src,test}/**/*.json": [
            "prettier --write"
        ]
    }
}
