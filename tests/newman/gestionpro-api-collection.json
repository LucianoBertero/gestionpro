{
  "info": {
    "name": "GestiónPro — API Completa",
    "description": "Colección Newman con todos los endpoints del backend consumidos desde el frontend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (SOCIO)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "pm.collectionVariables.set('accessToken', data.accessToken);",
                  "pm.collectionVariables.set('userId', data.user.id);",
                  "const cookie = pm.response.headers.get('set-cookie');",
                  "if (cookie) pm.collectionVariables.set('refreshCookie', cookie.split(';')[0]);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\"email\":\"admin@estudiobb.com\",\"password\":\"admin123\"}", "options": { "raw": { "language": "json" } } }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "{{refreshCookie}}" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["auth", "refresh-token"] }
          }
        },
        {
          "name": "Get Active Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/users", "host": ["{{baseUrl}}"], "path": ["auth", "users"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Cookie", "value": "{{refreshCookie}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        { "name": "Get Profile", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/user/profile", "host": ["{{baseUrl}}"], "path": ["user", "profile"] } } },
        { "name": "Update Profile", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"nombre\":\"Admin Actualizado\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] } } },
        { "name": "List Users (Admin)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/user", "host": ["{{baseUrl}}"], "path": ["admin", "user"] } } },
        { "name": "Get User (Admin)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["admin", "user", "{{userId}}"] } } }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        { "name": "List Clientes", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/clientes", "host": ["{{baseUrl}}"], "path": ["clientes"], "query": [{ "key": "search", "value": "", "disabled": true }, { "key": "semaforo", "value": "", "disabled": true }, { "key": "encargadoId", "value": "", "disabled": true }] } } },
        { "name": "Get Cliente by ID", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/clientes/1", "host": ["{{baseUrl}}"], "path": ["clientes", "1"] } } },
        { "name": "Get Cliente Legajo", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/clientes/1/legajo", "host": ["{{baseUrl}}"], "path": ["clientes", "1", "legajo"] } } },
        { "name": "Create Cliente", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"cuit\":\"30-12345678-9\",\"denominacion\":\"Test Cliente SA\",\"condicionIva\":\"Responsable Inscripto\",\"encargadoId\":\"{{userId}}\",\"tipoImpuesto\":[\"IVA\"]}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/clientes", "host": ["{{baseUrl}}"], "path": ["clientes"] } } },
        { "name": "AFIP Lookup", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/clientes/afip/30-12345678-9", "host": ["{{baseUrl}}"], "path": ["clientes", "afip", "30-12345678-9"] } } }
      ]
    },
    {
      "name": "Tareas",
      "item": [
        { "name": "List Tareas", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/tareas", "host": ["{{baseUrl}}"], "path": ["tareas"], "query": [{ "key": "estado", "value": "", "disabled": true }, { "key": "prioridad", "value": "", "disabled": true }, { "key": "encargadoId", "value": "", "disabled": true }] } } },
        { "name": "Get Tarea by ID", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/tareas/1", "host": ["{{baseUrl}}"], "path": ["tareas", "1"] } } },
        { "name": "Create Tarea", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"encargadoId\":\"{{userId}}\",\"titulo\":\"Test Tarea Newman\",\"tipo\":\"DDJJ\",\"impuesto\":\"IVA\",\"periodo\":\"2026-05\",\"prioridad\":\"MEDIA\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/admin/tareas", "host": ["{{baseUrl}}"], "path": ["admin", "tareas"] } } },
        { "name": "Update Tarea", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"estado\":\"EN_PROCESO\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/admin/tareas/1", "host": ["{{baseUrl}}"], "path": ["admin", "tareas", "1"] } } }
      ]
    },
    {
      "name": "Liquidaciones",
      "item": [
        { "name": "List Liquidaciones", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/liquidaciones", "host": ["{{baseUrl}}"], "path": ["liquidaciones"], "query": [{ "key": "clienteId", "value": "1", "disabled": true }] } } },
        { "name": "Get Liquidacion by ID", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/liquidaciones/1", "host": ["{{baseUrl}}"], "path": ["liquidaciones", "1"] } } },
        { "name": "Liquidaciones by Cliente", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/liquidaciones/cliente/1", "host": ["{{baseUrl}}"], "path": ["liquidaciones", "cliente", "1"] } } },
        { "name": "Historial Cliente", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/liquidaciones/cliente/1/historial", "host": ["{{baseUrl}}"], "path": ["liquidaciones", "cliente", "1", "historial"] } } },
        { "name": "Create Liquidacion", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"clienteId\":1,\"impuesto\":\"IVA\",\"periodo\":\"2026-05\",\"resultado\":\"A_PAGAR\",\"importe\":45000}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/admin/liquidaciones", "host": ["{{baseUrl}}"], "path": ["admin", "liquidaciones"] } } }
      ]
    },
    {
      "name": "Vencimientos",
      "item": [
        { "name": "List Vencimientos", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/vencimientos", "host": ["{{baseUrl}}"], "path": ["vencimientos"] } } },
        { "name": "Calcular Vencimiento", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/vencimientos/calcular", "host": ["{{baseUrl}}"], "path": ["vencimientos", "calcular"], "query": [{ "key": "cuit", "value": "30-12345678-9" }, { "key": "impuesto", "value": "IVA" }, { "key": "anio", "value": "2026" }, { "key": "mes", "value": "5" }] } } },
        { "name": "Cargar Vencimiento (Admin)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"impuesto\":\"IVA\",\"anio\":2026,\"mes\":5,\"digitoCuit\":9,\"fechaVence\":\"2026-05-20\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/admin/vencimientos/cargar", "host": ["{{baseUrl}}"], "path": ["admin", "vencimientos", "cargar"] } } }
      ]
    },
    {
      "name": "Agenda",
      "item": [
        { "name": "Get My Agenda", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/agenda", "host": ["{{baseUrl}}"], "path": ["agenda"], "query": [{ "key": "fechaDesde", "value": "2026-05-01", "disabled": true }, { "key": "fechaHasta", "value": "2026-05-31", "disabled": true }] } } },
        { "name": "Get Team Agenda (Admin)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/agenda/equipo", "host": ["{{baseUrl}}"], "path": ["admin", "agenda", "equipo"] } } },
        { "name": "Create Agenda Item", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"titulo\":\"Reunión equipo\",\"fecha\":\"2026-05-20T10:00:00Z\",\"duracionMin\":60,\"tipo\":\"ESTUDIO\",\"esEstudio\":true}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/admin/agenda", "host": ["{{baseUrl}}"], "path": ["admin", "agenda"] } } }
      ]
    },
    {
      "name": "Notificaciones",
      "item": [
        { "name": "Get My Notifications", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/notificaciones", "host": ["{{baseUrl}}"], "path": ["notificaciones"] } } },
        { "name": "Count Unread", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/notificaciones/no-leidas", "host": ["{{baseUrl}}"], "path": ["notificaciones", "no-leidas"] } } },
        { "name": "Mark All Read", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/notificaciones/leer-todas", "host": ["{{baseUrl}}"], "path": ["notificaciones", "leer-todas"] } } }
      ]
    },
    {
      "name": "Email Templates",
      "item": [
        { "name": "List Templates", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/email-templates", "host": ["{{baseUrl}}"], "path": ["admin", "email-templates"] } } },
        { "name": "Create Template", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"nombre\":\"Recordatorio Vencimiento\",\"tipo\":\"VENCIMIENTO\",\"asunto\":\"Vence {{impuesto}} - {{cliente}}\",\"cuerpo\":\"<p>Estimado/a {{cliente}},</p><p>Le recordamos que el {{fecha}} vence {{impuesto}}.</p>\"}", "options": { "raw": { "language": "json" } } }, "url": { "raw": "{{baseUrl}}/admin/email-templates", "host": ["{{baseUrl}}"], "path": ["admin", "email-templates"] } } }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        { "name": "Get Métricas", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/dashboard/metricas", "host": ["{{baseUrl}}"], "path": ["dashboard", "metricas"] } } },
        { "name": "Get Semáforos", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/dashboard/semaforos", "host": ["{{baseUrl}}"], "path": ["dashboard", "semaforos"] } } },
        { "name": "Tareas por Colaborador", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/dashboard/tareas-por-colaborador", "host": ["{{baseUrl}}"], "path": ["dashboard", "tareas-por-colaborador"] } } },
        { "name": "Vencimientos Semana", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/dashboard/vencimientos-semana", "host": ["{{baseUrl}}"], "path": ["dashboard", "vencimientos-semana"] } } }
      ]
    },
    {
      "name": "Financiero (Admin)",
      "item": [
        { "name": "Honorarios", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/financiero/honorarios", "host": ["{{baseUrl}}"], "path": ["admin", "financiero", "honorarios"] } } },
        { "name": "Rentabilidad", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/financiero/rentabilidad", "host": ["{{baseUrl}}"], "path": ["admin", "financiero", "rentabilidad"] } } },
        { "name": "Proyección", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/admin/financiero/proyeccion", "host": ["{{baseUrl}}"], "path": ["admin", "financiero", "proyeccion"] } } }
      ]
    },
    {
      "name": "Excel",
      "item": [
        { "name": "Export Clientes", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/excel/export/clientes", "host": ["{{baseUrl}}"], "path": ["excel", "export", "clientes"] } } },
        { "name": "Export Tareas", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/excel/export/tareas", "host": ["{{baseUrl}}"], "path": ["excel", "export", "tareas"] } } },
        { "name": "Export Liquidaciones", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/excel/export/liquidaciones", "host": ["{{baseUrl}}"], "path": ["excel", "export", "liquidaciones"] } } },
        { "name": "Export Vencimientos", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/excel/export/vencimientos", "host": ["{{baseUrl}}"], "path": ["excel", "export", "vencimientos"] } } }
      ]
    }
  ]
}
